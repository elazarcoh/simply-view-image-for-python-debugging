{
  "name": "svifpd-icons",
  "version": "0.0.1",
  "fontVersion": "0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "clean": "node ./scripts/reset.js",
    "svgo": "svgo -f ./src/icons/ --config svgo.config.js",
    "sprite": "node ./scripts/svg-sprite.js --outDir dist --outFile svifpd-icons.svg",
    "export-to-csv": "node ./scripts/export-to-csv.js -f ./dist/svifpd-icons.woff2 > ./dist/svifpd-icons.csv",
    "fonts": "fantasticon",
    "build": "yarn run clean && yarn run svgo && yarn run fonts && yarn run export-to-csv && yarn run sprite",
    "release": "release-it"
  },
  "devDependencies": {
    "ansi-regex": ">=6.0.1",
    "fantasticon": "^1.2.3",
    "opentype.js": "^1.3.3",
    "release-it": "19.0.2",
    "svg-sprite": "^2.0.2",
    "svgo": "2.8.2"
  }
}
